;; Mutation-Based Equivalence Benchmark
;; Source:     AutomatArk / instance03165.smt2
;; Mutations:  intersect_no_spaces
;; Status:     sat
;;
;; Original regex vs mutated regex
;; Equivalence check: unsat ⟺ L(R1) = L(R2)

(set-info :smt-lib-version 2.6)
(set-info :category "mutation")
(set-info :status sat)
(set-logic QF_S)


;; R1: original
;; R2: mutated (intersect_no_spaces)
(assert
  (not
    (=
      (re.++ (str.to_re "/\u{d}\u{a}Host: ") (re.+ (re.union (re.range "a" "z") (re.range "0" "9") (str.to_re "-") (str.to_re "."))) (str.to_re ".com-") (re.+ (re.union (re.range "a" "z") (re.range "0" "9") (str.to_re "-") (str.to_re "."))) (re.opt (re.++ (str.to_re ":") ((_ re.loop 1 5) (re.range "0" "9")))) (str.to_re "\u{d}\u{a}/Hi\u{a}"))
      (re.++ (str.to_re "/\u{d}\u{a}Host: ") (re.+ (re.inter (re.union (re.range "a" "z") (re.range "0" "9") (str.to_re "-") (str.to_re ".")) (re.comp (re.++ re.all (str.to_re " ") re.all)))) (str.to_re ".com-") (re.+ (re.union (re.range "a" "z") (re.range "0" "9") (str.to_re "-") (str.to_re "."))) (re.opt (re.++ (str.to_re ":") ((_ re.loop 1 5) (re.range "0" "9")))) (str.to_re "\u{d}\u{a}/Hi\u{a}")))))

(check-sat)
(exit)
