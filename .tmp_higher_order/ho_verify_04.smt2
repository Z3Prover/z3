; Verification: array initialization correctness
(set-logic HO_ALL)
(declare-const n Int)
(assert (> n 0))
(define-fun init_array ((val Int)) (Array Int Int)
  (lambda ((i Int)) (ite (and (>= i 0) (< i n)) val 0)))
(declare-const arr (Array Int Int))
(assert (= arr (init_array 42)))
(assert (not (forall ((i Int)) (=> (and (>= i 0) (< i n)) (= (select arr i) 42)))))
(check-sat)
(exit)
