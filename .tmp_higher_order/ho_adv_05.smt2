; Advanced: encoding of type classes (Eq class)
(set-logic HO_ALL)
(declare-sort T 0)
; An Eq instance is a binary predicate satisfying equivalence relation
(declare-fun eq () (-> T T Bool))
(assert (forall ((x T)) (eq x x)))
(assert (forall ((x T) (y T)) (=> (eq x y) (eq y x))))
(assert (forall ((x T) (y T) (z T)) (=> (and (eq x y) (eq y z)) (eq x z))))
(declare-fun a () T)
(declare-fun b () T)
(declare-fun c () T)
(assert (eq a b))
(assert (eq b c))
(assert (not (eq a c)))
(check-sat)
(exit)
