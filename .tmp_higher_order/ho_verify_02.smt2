; Verification: function contract
(set-logic HO_ALL)
(declare-fun pre () (-> Int Bool))
(declare-fun post () (-> Int Int Bool))
(declare-fun impl () (-> Int Int))
(assert (= pre (lambda ((x Int)) (>= x 0))))
(assert (= post (lambda ((x Int) (r Int)) (>= r x))))
(assert (= impl (lambda ((x Int)) (* x x))))
(assert (not (forall ((x Int)) (=> (pre x) (post x (impl x))))))
(check-sat)
(exit)
