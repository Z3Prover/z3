; Choice term: Axiom of Choice for functions
(set-logic HO_ALL)
(declare-sort A 0)
(declare-sort B 0)
(declare-fun R () (-> A B Bool))
(assert (forall ((a A)) (exists ((b B)) (R a b))))
(declare-fun f () (-> A B))
(assert (forall ((a A)) (= (f a) (choice ((b B)) (R a b)))))
(assert (not (forall ((a A)) (R a (f a)))))
(check-sat)
(exit)
