; Higher-order lambda: function composition
(set-logic HO_ALL)
(define-fun compose ((f (-> Int Int)) (g (-> Int Int))) (-> Int Int)
  (lambda ((x Int)) (f (g x))))
(declare-fun inc () (-> Int Int))
(assert (= inc (lambda ((x Int)) (+ x 1))))
(declare-fun double () (-> Int Int))
(assert (= double (lambda ((x Int)) (* 2 x))))
(assert (not (= ((compose inc double) 3) 7)))
(check-sat)
(exit)
