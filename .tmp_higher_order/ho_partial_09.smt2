; Partial application: pointfree filter condition
(set-logic HO_ALL)
(declare-const data (Array Int Int))
(define-fun gt_than ((threshold Int)) (-> Int Bool)
  (lambda ((x Int)) (> x threshold)))
(declare-const mask (Array Int Bool))
(assert (= mask (lambda ((i Int)) ((gt_than 10) (select data i)))))
(assert (= (select data 0) 15))
(assert (= (select data 1) 5))
(assert (not (and (select mask 0) (not (select mask 1)))))
(check-sat)
(exit)
