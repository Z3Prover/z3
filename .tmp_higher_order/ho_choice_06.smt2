; Choice term: dependent choice for sequences
(set-logic HO_ALL)
(declare-fun R () (-> Int Int Bool))
(assert (forall ((x Int)) (exists ((y Int)) (R x y))))
(declare-fun seq () (-> Int Int))
(assert (= (seq 0) 0))
(assert (forall ((n Int)) (=> (>= n 0)
  (= (seq (+ n 1)) (choice ((y Int)) (R (seq n) y))))))
(assert (not (R (seq 0) (seq 1))))
(check-sat)
(exit)
