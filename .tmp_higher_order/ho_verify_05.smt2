; Verification: higher-order specification
; A sort function must produce ordered output
(set-logic HO_ALL)
(declare-fun sorted () (-> (Array Int Int) Int Bool))
(assert (forall ((a (Array Int Int)) (n Int))
  (= (sorted a n)
     (forall ((i Int)) (=> (and (>= i 0) (< i (- n 1)))
                           (<= (select a i) (select a (+ i 1))))))))
(declare-fun sort_fn () (-> (Array Int Int) Int (Array Int Int)))
(assert (forall ((a (Array Int Int)) (n Int))
  (sorted (sort_fn a n) n)))
(declare-const input (Array Int Int))
(assert (= (select input 0) 3))
(assert (= (select input 1) 1))
(assert (= (select input 2) 2))
(declare-const output (Array Int Int))
(assert (= output (sort_fn input 3)))
(assert (not (and (<= (select output 0) (select output 1))
                  (<= (select output 1) (select output 2)))))
(check-sat)
(exit)
