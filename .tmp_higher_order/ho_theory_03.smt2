; HO + Arrays: filter predicate
(set-logic HO_ALL)
(declare-const a (Array Int Int))
(declare-const mask (Array Int Bool))
(assert (= mask (lambda ((i Int)) (> (select a i) 0))))
(assert (= (select a 0) 5))
(assert (= (select a 1) (- 3)))
(assert (not (and (select mask 0) (not (select mask 1)))))
(check-sat)
(exit)
