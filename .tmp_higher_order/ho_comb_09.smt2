; Higher-order: B combinator (composition)
(set-logic HO_ALL)
(define-fun B ((f (-> Int Int)) (g (-> Int Int)) (x Int)) Int (f (g x)))
(declare-fun negate () (-> Int Int))
(declare-fun double () (-> Int Int))
(assert (= negate (lambda ((x Int)) (- 0 x))))
(assert (= double (lambda ((x Int)) (* 2 x))))
(assert (not (= (B negate double 5) (- 10))))
(check-sat)
(exit)
